<section class="gift-grid page-width">
<div class="gift-grid__header">
  <h2>{{ section.settings.heading }}</h2>

  {% if section.settings.view_all_link != blank %}
    <a
      href="{{ section.settings.view_all_link }}"
      class="gift-grid__view-all"
    >
      View all
    </a>
  {% endif %}
</div>

  <div class="gift-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}

      {% if product %}
        <div class="gift-card" {{ block.shopify_attributes }}>

          <div class="gift-card__image">

            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.title }}"
              loading="lazy"
            >

            <button
  class="gift-card__plus"
  data-title="{{ product.title }}"
  data-price="{{ product.price | money }}"
  data-image="{{ product.featured_image | image_url: width: 900 }}"
  data-description="{{ product.description | strip_html | escape }}"
>
  +
</button>

          </div>

          

        </div>
      {% endif %}
    {% endfor %}
  </div>

</section>

<style>

.gift-grid{
    padding:80px 20px;
}

.gift-grid__header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:50px;
}

.gift-grid__header h2{
    margin:0;
    font-size:42px;
    font-weight:600;
}

.gift-grid__view-all{
    text-decoration:none;
    color:#000;
    font-weight:500;
}

.gift-grid__items{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
}

.gift-card img{
    width:100%;
    aspect-ratio:1/1;
    object-fit:cover;
    display:block;
}

.gift-card__image{
    position:relative;
    overflow:visible;
}
.gift-card__plus{
    position:absolute !important;
    top:50% !important;
    right:180px !important;
    transform:translateY(-50%) !important;
    width:46px;
    height:46px;
    border-radius:50%;
    border:none;
    background:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:28px;
    cursor:pointer;
    z-index:999;
    box-shadow:0 4px 12px rgba(0,0,0,.15);
}
.gift-card__plus:hover{
    transform:translateY(-50%) scale(1.08);
}

.gift-card h3{
    margin-top:20px;
    font-size:18px;
}

.gift-card p{
    font-weight:bold;
}

@media(max-width:768px){

.gift-grid__items{
grid-template-columns:1fr;
}

}
.gift-popup{
    position:fixed;
    inset:0;
    display:none;
    align-items:center;
    justify-content:center;
    background:rgba(0,0,0,.45);
    z-index:999;
}

.gift-popup.active{
    display:flex;
}

.gift-popup__overlay{
    position:absolute;
    inset:0;
}

.gift-popup__content{
    position:relative;
    background:#fff;
    width:620px;
    max-width:90%;
    display:grid;
    grid-template-columns:170px 1fr;
    gap:20px;
    padding:20px;
    border-radius:4px;
    z-index:2;
}

.gift-popup__left img{
    width:100%;
    display:block;
}

.gift-popup__right h2{
    margin:0;
    font-size:34px;
    line-height:1.1;
}

.gift-popup__close{
    position:absolute;
    top:15px;
    right:15px;
    border:none;
    background:none;
    font-size:30px;
    cursor:pointer;
}
.popup-colors{
display:flex;
margin:15px 0;
}

.popup-colors button{
flex:1;
padding:14px;
border:1px solid #ddd;
background:#fff;
cursor:pointer;
}

.gift-popup select{
width:100%;
padding:14px;
margin:15px 0 25px;
}

#popupPrice{
font-size:24px;
font-weight:600;
margin:15px 0;
}

#popupDescription{
margin-bottom:20px;
line-height:1.6;
}

</style>
<div class="gift-popup" id="giftPopup">

  <div class="gift-popup__overlay"></div>

  <div class="gift-popup__content">

    <button class="gift-popup__close">&times;</button>

    <div class="gift-popup__left">
      <img id="popupImage">
    </div>

    <div class="gift-popup__right">

      <h2 id="popupTitle"></h2>

      <div id="popupPrice"></div>

      <p id="popupDescription"></p>

      <label>Color</label>

      <div class="popup-colors">
        <button>White</button>
        <button>Black</button>
      </div>

      <label>Size</label>

      <select>
        <option>Choose your size</option>
        <option>Small</option>
        <option>Medium</option>
        <option>Large</option>
      </select>

      <button id="popupAddToCart" class="gift-banner__button">
        ADD TO CART →
      </button>

    </div>

  </div>

</div>
{% schema %}
{
  "name":"Gift Grid",
  "settings":[
  {
    "type":"text",
    "id":"heading",
    "label":"Heading",
    "default":"Shop Gifts"
  },
  {
    "type":"url",
    "id":"view_all_link",
    "label":"View All Link"
  }

  ],
  "blocks":[
    {
      "type":"product",
      "name":"Product",
      "settings":[
        {
          "type":"product",
          "id":"product",
          "label":"Select Product"
        }
      ]
    }
  ],
  "max_blocks":6,
  "presets":[
    {
      "name":"Gift Grid"
    }
  ]
}
{% endschema %}
<script>
document.addEventListener("DOMContentLoaded", function () {

  const popup = document.getElementById("giftPopup");

  const popupImage = document.getElementById("popupImage");
  const popupTitle = document.getElementById("popupTitle");
  const popupPrice = document.getElementById("popupPrice");
  const popupDescription = document.getElementById("popupDescription");

  document.querySelectorAll(".gift-card__plus").forEach(function(button){

   button.addEventListener("click", function(){

  console.log(this.dataset);

  popupImage.src = this.dataset.image;
  popupTitle.textContent = this.dataset.title;
  popupPrice.textContent = this.dataset.price;
  popupDescription.textContent = this.dataset.description;

  popup.classList.add("active");

});

  });

  document.querySelector(".gift-popup__close").addEventListener("click", function(){
    popup.classList.remove("active");
  });

  document.querySelector(".gift-popup__overlay").addEventListener("click", function(){
    popup.classList.remove("active");
  });

});
</script>