<section class="gift-grid page-width">
<div class="gift-grid__header">
  <h2>{{ section.settings.heading }}</h2>

  {% if section.settings.view_all_link != blank %}
    <a
      href="{{ section.settings.view_all_link }}"
      class="gift-grid__view-all"
    >
      View all
    </a>
  {% endif %}
</div>

  <div class="gift-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}

      {% if product %}
        <div class="gift-card" {{ block.shopify_attributes }}>

          <div class="gift-card__image">

            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.title }}"
              loading="lazy"
            >

            <button
              class="gift-card__plus"
              data-product-handle="{{ product.handle }}"
            >
              +
            </button>

          </div>

          

        </div>
      {% endif %}
    {% endfor %}
  </div>

</section>

<style>

.gift-grid{
    padding:80px 20px;
}

.gift-grid__header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:50px;
}

.gift-grid__header h2{
    margin:0;
    font-size:42px;
    font-weight:600;
}

.gift-grid__view-all{
    text-decoration:none;
    color:#000;
    font-weight:500;
}

.gift-grid__items{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
}

.gift-card img{
    width:100%;
    aspect-ratio:1/1;
    object-fit:cover;
    display:block;
}

.gift-card__image{
    position:relative;
}

.gift-card__plus{
    position:absolute;
    top:16px;
    right:16px;
    width:42px;
    height:42px;
    border:none;
    border-radius:50%;
    background:#fff;
    color:#000;
    cursor:pointer;
    font-size:24px;
    display:flex;
    align-items:center;
    justify-content:center;
    box-shadow:0 2px 8px rgba(0,0,0,.12);
    transition:.3s;
}

.gift-card__plus:hover{
    transform:scale(1.08);
}

.gift-card h3{
    margin-top:20px;
    font-size:18px;
}

.gift-card p{
    font-weight:bold;
}

@media(max-width:768px){

.gift-grid__items{
grid-template-columns:1fr;
}

}

</style>

{% schema %}
{
  "name":"Gift Grid",
  "settings":[
  {
    "type":"text",
    "id":"heading",
    "label":"Heading",
    "default":"Shop Gifts"
  },
  {
    "type":"url",
    "id":"view_all_link",
    "label":"View All Link"
  }
  
  ],
  "blocks":[
    {
      "type":"product",
      "name":"Product",
      "settings":[
        {
          "type":"product",
          "id":"product",
          "label":"Select Product"
        }
      ]
    }
  ],
  "max_blocks":6,
  "presets":[
    {
      "name":"Gift Grid"
    }
  ]
}
{% endschema %}