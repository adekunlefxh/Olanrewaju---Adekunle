<section class="gift-grid page-width">

  <div class="gift-grid__header">
    <h2>{{ section.settings.heading }}</h2>
  </div>

  <div class="gift-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}

      {% if product %}
        <div class="gift-card" {{ block.shopify_attributes }}>

          <div class="gift-card__image">

            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.title }}"
              loading="lazy"
            >

            <button
              class="gift-card__plus"
              data-product-handle="{{ product.handle }}"
            >
              +
            </button>

          </div>

          <h3>{{ product.title }}</h3>

          <p>{{ product.price | money }}</p>

        </div>
      {% endif %}
    {% endfor %}
  </div>

</section>

<style>

.gift-grid{
    padding:80px 20px;
}

.gift-grid__header{
    text-align:center;
    margin-bottom:50px;
}

.gift-grid__items{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:30px;
}

.gift-card img{
    width:100%;
    display:block;
}

.gift-card__image{
    position:relative;
}

.gift-card__plus{
    position:absolute;
    right:15px;
    bottom:15px;
    width:45px;
    height:45px;
    border:none;
    border-radius:50%;
    cursor:pointer;
    font-size:22px;
}

.gift-card h3{
    margin-top:20px;
    font-size:18px;
}

.gift-card p{
    font-weight:bold;
}

@media(max-width:768px){

.gift-grid__items{
grid-template-columns:1fr;
}

}

</style>

{% schema %}
{
  "name":"Gift Grid",
  "settings":[
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Shop Gifts"
    }
  ],
  "blocks":[
    {
      "type":"product",
      "name":"Product",
      "settings":[
        {
          "type":"product",
          "id":"product",
          "label":"Select Product"
        }
      ]
    }
  ],
  "max_blocks":6,
  "presets":[
    {
      "name":"Gift Grid"
    }
  ]
}
{% endschema %}